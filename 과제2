#include <stdio.h>
int main() {
    int n;

    //파보나치 수열의 첫째항, 둘째 항 초기화
    long long n1 = 1;
    long long n2 = 1;
    long long next;

    printf("구하고자하는 피보나치 수열의 순서를 입력하세요");
    scanf("%d", &n);

    //예외처리: 1보다 작은 수 입력
    if (n <= 0) {
        printf("1이상의 정수를 입력하세요");
        return 0;
    }

    // 1번째나 2번째 수는 계산할 필요 없이 바로 1입니다.
    if (n == 1 || n == 2) {
        printf("%d번째 피보나치 수는 1입니다.\n", n);
    }
    else {
        // 3번째 항부터 n번째 항까지 반복하여 계산
        for (int i = 3; i <= n; i++) {
            next = n1 + n2; // 앞의 두 수를 더함
            n1 = n2;        // n1을 다음 칸(n2)으로 이동
            n2 = next;      // n2를 새로 계산된 값(next)으로 이동
        }

        // 반복문이 끝나면 n2에 n번째 피보나치 수가 저장됩니다.
        printf("%d번째 피보나치 수는 %lld입니다.\n", n, n2);
    }

    return 0;
}

