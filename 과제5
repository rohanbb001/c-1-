#include <stdio.h>

int main() {
    int N;

    printf("값을 입력하세요 . ");
    if (scanf("%d", &N) != 1) {
        return 0;
    }

    // --- 1. 상단부 출력 (1번째 줄부터 N번째 줄까지) ---
    for (int i = 1; i <= N; i++) {
        // 왼쪽 별 출력 (i개)
        for (int j = 0; j < i; j++) {
            printf("*");
        }

        // 가운데 공백 출력 (2 * (N - i)개)
        for (int j = 0; j < 2 * (N - i); j++) {
            printf(" ");
        }

        // 오른쪽 별 출력 (i개)
        for (int j = 0; j < i; j++) {
            printf("*");
        }

        printf("\n"); // 줄바꿈
    }

    // --- 2. 하단부 출력 (N-1번째 줄부터 1번째 줄까지 대칭 출력) ---
    for (int i = N - 1; i >= 1; i--) {
        // 왼쪽 별 출력 (i개)
        for (int j = 0; j < i; j++) {
            printf("*");
        }

        // 가운데 공백 출력 (2 * (N - i)개)
        for (int j = 0; j < 2 * (N - i); j++) {
            printf(" ");
        }

        // 오른쪽 별 출력 (i개)
        for (int j = 0; j < i; j++) {
            printf("*");
        }

        printf("\n"); // 줄바꿈
    }

    return 0;
}
