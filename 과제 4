 
 #include <stdio.h>
#include <math.h>
 int main(){
    double num1, num2;
    char op;
    double result;
    int is_valid = 1;

    printf("===계산기===\n");  
    printf("사용가능한 연산자: +, -, *, /, ^\n");
    
    //실수, 연산자 실수 순으로 입력
    printf("첫 번째 실수를 입력하세요: ");
    scanf("%lf", &num1);
    printf("연산자를 입력하세요: ");
    scanf(" %c", &op);
    printf("두 번째 실수를 입력하세요: ");
    scanf("%lf", &num2);

    if(scanf("%lf %c %lf", &num1, &op, &num2) != 3) {
        printf("잘못된 입력입니다. 프로그램을 종료합니다.\n");
        return 1;
    }   
    //계산 진행
    switch(op) {
        case '+':
            result = num1 + num2;
            break;
        case '-':
            result = num1 - num2;
            break;
        case '*':
            result = num1 * num2;
            break;
        case '/':
            if(num2 == 0) {
                printf("0으로 나눌 수 없습니다. 프로그램을 종료합니다.\n");
                is_valid = 0;
            } else {
                result = num1 / num2;
            }
            break;
        case '^':
            result = pow(num1, num2);
            break;
        default:
            printf("잘못된 연산자입니다. 프로그램을 종료합니다.\n");
            is_valid = 0;
    }
    if(is_valid) {
        printf("결과: %.2lf\n", result);
    }
    return 0;
 }
